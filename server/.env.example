# =============================================
# FOAM FOX AUTO DETAILING — Server Environment
# Copy this file to .env and fill in values
# =============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB — get from https://cloud.mongodb.com (free tier)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/foamfox?retryWrites=true&w=majority

# CORS — your frontend URL (in production)
CLIENT_ORIGIN=http://localhost:3000

# Admin authentication (for /api/bookings GET)
# Change this to a secure random string before deploying!
ADMIN_SECRET=change-this-to-a-secure-random-string

# Email — optional but strongly recommended
# Using Gmail: enable "App Passwords" in your Google Account settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# Who receives admin notifications
ADMIN_EMAIL=foamfox.detailing@gmail.com
